{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Routing expected",
  "description": "Router target. Input is {\"question\": \"...\"}; expected is the set of routes plus whether asking a clarifying question is acceptable.",
  "type": "object",
  "properties": {
    "routes": {
      "type": "array",
      "items": { "type": "string", "enum": ["sql", "rag", "smalltalk"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "clarify_ok": { "type": "boolean" }
  },
  "required": ["routes", "clarify_ok"],
  "additionalProperties": false
}
