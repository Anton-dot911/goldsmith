# Goldsmith deploy environment. On Netlify these are set under
# Site settings → Environment variables. Locally, `netlify dev` reads them from
# a repo-root `.env` (gitignored). The web app's Vite vars also live in
# web/.env for a plain `vite` dev server (see web/.env.example).
#
# ── Build-time / browser (Vite) ────────────────────────────────────────────
# Exposed in the client bundle. Safe: the anon key is confined by RLS and, after
# migration 003, requires an authenticated (logged-in) session for goldsmith
# data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Runtime / server-side (Netlify Functions only — never exposed) ──────────
# The AI pre-label call uses the Anthropic key server-side (CLAUDE.md rule 5).
ANTHROPIC_API_KEY=
# Optional: override the draft model (default: claude-haiku-4-5-20251001).
DRAFT_MODEL=

# Bearer token gating the CI export endpoint
# (GET /.netlify/functions/export?dataset=<slug>&version=<n>).
EXPORT_TOKEN=

# Supabase service-role key + URL, used ONLY inside functions to read the
# dataset schema, sign storage URLs for file inputs, write the llm_calls meter
# row, and serve the export. Never ship this to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
